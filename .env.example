# Chave mestra do Rails (copiar do config/master.key)
RAILS_MASTER_KEY=

# Vinculada automaticamente pelo Render
DATABASE_URL=

# Configurações de produção
RAILS_ENV=production
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# Opcional: API-Football para o dashboard de futebol
API_FOOTBALL_KEY=
