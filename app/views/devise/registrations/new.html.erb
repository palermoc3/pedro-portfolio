<div class="auth-page">
  <div class="auth-card">

    <h2 class="auth-title">
      Criar conta
    </h2>
    <p class="auth-subtitle">Preencha os dados para se cadastrar</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :name, "Nome completo", class: "form-label" %>
        <%= f.text_field :name, autofocus: true,
            class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, autocomplete: "email",
            class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :age, "Idade", class: "form-label" %>
        <%= f.number_field :age, min: 1, max: 120,
            class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :club, "Time de futebol", class: "form-label" %>
        <%= f.select :club,
          options_for_select([["Selecione seu time", ""]] + User::SERIE_A_CLUBS.map { |c| [c, c] }),
          {},
           class: "form-select" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "form-input" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "Confirmar senha", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "form-input" %>
      </div>

      <%= f.submit "Criar conta", class: "btn-primary-full" %>

    <% end %>

    <div class="mt-6 text-center text-sm text-muted">
      Já tem conta?
      <%= link_to "Entrar", new_session_path(resource_name), class: "text-link" %>
    </div>

  </div>
</div>
