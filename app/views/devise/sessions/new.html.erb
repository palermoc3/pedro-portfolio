<div class="auth-page">
  <div class="auth-card">

    <h2 class="auth-title">
      Entrar
    </h2>
    <p class="auth-subtitle">Acesse sua conta para ver o dashboard</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-group">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "form-input" %>
      </div>

      <div class="mb-6 flex items-center gap-2">
        <%= f.check_box :remember_me, class: "accent-electric" %>
        <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-muted" %>
      </div>

      <%= f.submit "Entrar", class: "btn-primary-full" %>

    <% end %>

    <div class="mt-6 text-center text-sm text-muted">
      Não tem conta?
      <%= link_to "Cadastre-se", new_registration_path(resource_name), class: "text-link" %>
    </div>

  </div>
</div>
