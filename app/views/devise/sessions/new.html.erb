<div class="min-h-screen bg-[#0F172A] flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-[#1E293B] rounded-2xl p-8 shadow-xl">

    <h2 class="text-3xl font-bold text-[#F1F5F9] mb-2" style="font-family: 'Space Grotesk', sans-serif;">
      Entrar
    </h2>
    <p class="text-[#94A3B8] mb-8 text-sm">Acesse sua conta para ver o dashboard</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="mb-5">
        <%= f.label :email, "E-mail", class: "block text-sm text-[#94A3B8] mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full bg-[#0F172A] text-[#F1F5F9] border border-[#334155] rounded-lg px-4 py-3 focus:outline-none focus:border-[#6366F1] transition" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, "Senha", class: "block text-sm text-[#94A3B8] mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full bg-[#0F172A] text-[#F1F5F9] border border-[#334155] rounded-lg px-4 py-3 focus:outline-none focus:border-[#6366F1] transition" %>
      </div>

      <div class="mb-6 flex items-center gap-2">
        <%= f.check_box :remember_me, class: "accent-[#6366F1]" %>
        <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-[#94A3B8]" %>
      </div>

      <%= f.submit "Entrar", class: "w-full bg-[#6366F1] hover:bg-[#4F46E5] text-white font-semibold py-3 rounded-lg transition cursor-pointer" %>

    <% end %>

    <div class="mt-6 text-center text-sm text-[#94A3B8]">
      Não tem conta?
      <%= link_to "Cadastre-se", new_registration_path(resource_name), class: "text-[#6366F1] hover:underline" %>
    </div>

  </div>
</div>