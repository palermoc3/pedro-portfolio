<!DOCTYPE html>
<html lang="pt-BR" style="scroll-behavior: smooth;">
  <head>
    <title><%= content_for(:title) || "Pedro Portfolio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <!-- Chart.js para Chartkick -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Chartkick JS -->
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.0"></script>
  </head>

  <!-- O segredo está aqui: adicionamos flex, flex-col e min-h-screen no body -->
  <body class="bg-[#0F172A] text-[#F1F5F9] flex flex-col min-h-screen" style="font-family: 'Inter', sans-serif;">

      <%= render "shared/navbar" %>

    <!-- Envelopamos o yield em uma tag main com flex-grow para empurrar o footer -->
    <main class="flex-grow">
      <%= yield %>
    </main>
      <%= render "shared/footer" %>

  </body>
</html>