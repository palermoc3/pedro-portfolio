<!DOCTYPE html>
<html lang="pt-BR" style="scroll-behavior: smooth;">
  <head>
    <title><%= content_for(:title) || "Pedro Portfolio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">


    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <!-- Chart.js para Chartkick -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Chartkick JS -->
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.0"></script>
  </head>

  <!-- O segredo está aqui: adicionamos flex, flex-col e min-h-screen no body -->
  <body class="bg-[#0F172A] text-[#F1F5F9] flex flex-col min-h-screen" style="font-family: 'Inter', sans-serif;">

<!-- Navbar Fixa/Sticky -->
<nav class="sticky top-0 z-50 bg-[#0F172A]/80 backdrop-blur-md border-b border-slate-800 px-6 py-4">
  <div class="max-w-6xl mx-auto flex justify-between items-center">
    <!-- Logo / Nome -->
    <a href="#" class="text-xl font-bold font-['Space_Grotesk'] text-[#F1F5F9]">
      Palermo<span class="text-indigo-500">.dev</span>
    </a>

    <!-- Links de Navegação e Ações -->
    <div class="flex space-x-6 text-sm font-medium text-[#94A3B8] items-center">
<%= link_to "Início", root_path(anchor: "Hero"),
    class: "text-indigo-400 hover:text-indigo-300 bg-indigo-500/10 hover:bg-indigo-500/20 px-4 py-2 rounded-lg border border-indigo-500/20 transition-colors text-sm font-medium text-center inline-block" %>
    
    <%= link_to "Sobre", root_path(anchor: "sobre"),
    class: "text-indigo-400 hover:text-indigo-300 bg-indigo-500/10 hover:bg-indigo-500/20 px-4 py-2 rounded-lg border border-indigo-500/20 transition-colors text-sm font-medium text-center inline-block" %>

<%= link_to "Projetos", root_path(anchor: "projetos"),
    class: "text-indigo-400 hover:text-indigo-300 bg-indigo-500/10 hover:bg-indigo-500/20 px-4 py-2 rounded-lg border border-indigo-500/20 transition-colors text-sm font-medium text-center inline-block" %>

<%= link_to "Contato", root_path(anchor: "contato"),
    class: "text-indigo-400 hover:text-indigo-300 bg-indigo-500/10 hover:bg-indigo-500/20 px-4 py-2 rounded-lg border border-indigo-500/20 transition-colors text-sm font-medium text-center inline-block" %>
    
      <% if user_signed_in? %>
        <%= button_to "Sair",
            destroy_user_session_path,
            method: :delete,
            form_class: "inline",
            class: "text-red-400 hover:text-red-300 bg-red-500/10 hover:bg-red-500/20 px-4 py-2 rounded-lg border border-red-500/20 transition-colors text-sm font-medium cursor-pointer vertical-align-middle" %>
      <% else %>
        <%= link_to "Entrar", 
            new_user_session_path, 
            class: "text-indigo-400 hover:text-indigo-300 bg-indigo-500/10 hover:bg-indigo-500/20 px-4 py-2 rounded-lg border border-indigo-500/20 transition-colors text-sm font-medium text-center inline-block" %>
      <% end %>
    </div>
  </div>
</nav>

    <!-- Envelopamos o yield em uma tag main com flex-grow para empurrar o footer -->
    <main class="flex-grow">
      <%= yield %>
    </main>

    <footer class="bg-[#1E293B] border-t border-slate-700 py-6 text-center text-[#94A3B8]">
      © <%= Date.current.year %> Pedro Palermo
    </footer>
  </body>
</html>