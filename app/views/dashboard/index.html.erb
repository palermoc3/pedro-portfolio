<div class="min-h-screen bg-midnight p-6">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-3xl font-bold text-soft-white font-title mb-2">
      Dashboard
    </h1>
    <p class="text-muted mb-8">
      Olá, <span class="text-electric font-semibold"><%= current_user.name %></span> — bem-vindo à área restrita.
    </p>

    <!-- Grid 2x2: [a1, a2] [b1, b2] -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- COLUNA ESQUERDA: a1 + b1 (Tabela + Paginação) -->
      <div class="flex flex-col gap-8">
        
        <!-- Quadrante a1: Tabela de usuários cadastrados -->
        <div class="bg-slate rounded-xl p-6">
          <h2 class="text-xl font-bold text-soft-white font-title mb-4">
            Usuários Cadastrados
          </h2>
          <p class="text-muted text-sm mb-4">
            <%= @total_users %> no total
          </p>

          <!-- Tabela responsiva -->
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-midnight/30">
                  <th class="text-left py-3 px-4 text-muted font-semibold">Nome</th>
                  <th class="text-left py-3 px-4 text-muted font-semibold">Time</th>
                  <th class="text-left py-3 px-4 text-muted font-semibold">Idade</th>
                  <th class="text-left py-3 px-4 text-muted font-semibold">Cadastro</th>
                </tr>
              </thead>
              <tbody>
                <% @recent_users.each do |user| %>
                  <tr class="border-b border-midnight/20 hover:bg-midnight/20 transition-colors">
                    <td class="py-3 px-4 text-soft-white">
                      <div class="flex items-center gap-2">
                        <%= user.name %>
                        <% if user == current_user %>
                          <span class="inline-flex items-center rounded-full bg-success/20 px-2 py-1 text-xs font-medium text-success">
                            você
                          </span>
                        <% end %>
                      </div>
                    </td>
                    <td class="py-3 px-4 text-soft-white"><%= user.club %></td>
                    <td class="py-3 px-4 text-soft-white"><%= user.age %> anos</td>
                    <td class="py-3 px-4 text-muted">
                      <%= user.created_at.strftime("%d/%m/%Y") %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <% if @recent_users.empty? %>
            <div class="text-center py-8 text-muted">
              Nenhum usuário cadastrado ainda.
            </div>
          <% end %>
        </div>

        <!-- Quadrante b1: Paginação -->
        <div class="bg-slate rounded-xl p-6">
          <div class="flex justify-center">
            <%= paginate @recent_users %>
          </div>
        </div>

      </div>

      <!-- COLUNA DIREITA: a2 + b2 (Gráficos) -->
      <div class="flex flex-col gap-8">
        
        <!-- Quadrante a2: Gráfico Pizza - Distribuição de Times -->
        <div class="bg-slate rounded-xl p-6">
          <h2 class="text-xl font-bold text-soft-white font-title mb-4">
            Distribuição de Times
          </h2>
          <div class="h-80">
            <%= pie_chart @clubs_chart, 
                colors: ["#6366F1", "#10B981", "#F59E0B", "#EF4444", "#3B82F6", "#EC4899", "#14B8A6", "#F97316", "#8B5CF6", "#06B6D4", "#84CC16", "#EAB308", "#64748B", "#475569", "#6B7280", "#9CA3AF", "#D1D5DB", "#E5E7EB", "#F3F4F6", "#FFFFFF"] %>
          </div>
        </div>

        <!-- Quadrante b2: Gráfico Barras - Faixa Etária -->
        <div class="bg-slate rounded-xl p-6">
          <h2 class="text-xl font-bold text-soft-white font-title mb-4">
            Faixa Etária
          </h2>
          <div class="h-80">
            <%= bar_chart @age_chart, 
                colors: ["#6366F1"] %>
          </div>
        </div>

      </div>

    </div>

    <!-- Quadrante c: Tabela da API - Brasileirão (linha inteira) -->
    <div class="mt-8 bg-slate rounded-xl p-6">
      <h2 class="text-xl font-bold text-soft-white font-title mb-4">
        Brasileirão 2024 — Top 10
      </h2>
      <p class="text-muted text-sm mb-4">
        Classificação ao vivo via API-Football
      </p>

      <!-- Tabela responsiva -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-midnight/30">
              <th class="text-left py-3 px-4 text-muted font-semibold">Pos.</th>
              <th class="text-left py-3 px-4 text-muted font-semibold">Time</th>
              <th class="text-center py-3 px-4 text-muted font-semibold">Jogos</th>
              <th class="text-center py-3 px-4 text-muted font-semibold">Vitórias</th>
              <th class="text-center py-3 px-4 text-muted font-semibold">Empates</th>
              <th class="text-center py-3 px-4 text-muted font-semibold">Derrotas</th>
              <th class="text-center py-3 px-4 text-muted font-semibold">Gols</th>
              <th class="text-center py-3 px-4 text-muted font-semibold">Pontos</th>
            </tr>
          </thead>
          <tbody>
            <% @standings.each do |team| %>
              <tr class="border-b border-midnight/20 hover:bg-midnight/20 transition-colors">
                <td class="py-3 px-4 text-soft-white font-semibold">
                  <% if team[:position] <= 4 %>
                    <span class="inline-flex items-center rounded-full bg-electric/20 px-2 py-1 text-xs font-medium text-electric">
                      <%= team[:position] %>
                    </span>
                  <% elsif team[:position] <= 6 %>
                    <span class="inline-flex items-center rounded-full bg-soft-white/10 px-2 py-1 text-xs font-medium text-soft-white">
                      <%= team[:position] %>
                    </span>
                  <% else %>
                    <%= team[:position] %>
                  <% end %>
                </td>
                <td class="py-3 px-4 text-soft-white"><strong><%= team[:team_name] %></strong></td>
                <td class="py-3 px-4 text-center text-muted"><%= team[:played] %></td>
                <td class="py-3 px-4 text-center text-success"><%= team[:wins] %></td>
                <td class="py-3 px-4 text-center text-muted"><%= team[:draws] %></td>
                <td class="py-3 px-4 text-center text-red-400"><%= team[:losses] %></td>
                <td class="py-3 px-4 text-center text-muted">
                  <% if team[:goal_diff] > 0 %>
                    <span class="text-success">+<%= team[:goal_diff] %></span>
                  <% elsif team[:goal_diff] < 0 %>
                    <span class="text-red-400"><%= team[:goal_diff] %></span>
                  <% else %>
                    <span class="text-muted">=<%= team[:goal_diff] %></span>
                  <% end %>
                </td>
                <td class="py-3 px-4 text-center">
                  <span class="inline-flex items-center rounded-full bg-electric/20 px-3 py-1 font-bold text-electric">
                    <%= team[:points] %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @standings.empty? %>
        <div class="text-center py-8 text-muted">
          Erro ao carregar dados da API. Exibindo dados de fallback.
        </div>
      <% end %>
    </div>
  </div>
</div>