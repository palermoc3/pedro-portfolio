<div class="page-shell">
  <div class="content-container-wide store-dashboard">
    <header class="store-dashboard-header">
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-success">
          Loja virtual
        </p>
        <h1 class="section-title mb-2">
          Dashboard da loja
        </h1>
        <p class="max-w-3xl text-muted">
          Um recorte público de portfólio que mostra como uma base analítica de ecommerce pode ser transformada em KPIs, gráficos e contratos de dados consumidos por Rails.
        </p>
      </div>

    </header>

    <section class="store-data-note">
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-success">
          Sobre este projeto
        </p>
        <h2 class="panel-title mb-2">
          Dados governados, payload estático e consumo Rails
        </h2>
        <p class="max-w-5xl text-sm leading-6 text-muted">
          Este dashboard é uma página pública do portfólio. Os números vêm de uma planilha sintética de ecommerce MEI chamada
          <span class="font-semibold text-soft-white">dataset_analitico_mei.xlsx</span>. Um script Python lê as abas de vendas, clientes,
          produtos, carrinhos e avaliações, aplica regras de negócio documentadas e exporta JSONs em <span class="font-semibold text-soft-white">public/</span>.
          A página Rails consome esses arquivos para demonstrar integração entre análise de dados, contrato de API e frontend executivo.
        </p>
      </div>

      <div class="store-data-note-grid">
        <article class="store-data-pill">
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-success">
            Fonte
          </p>
          <p class="text-sm leading-6 text-muted">
            A receita de pedidos é calculada deduplicando <span class="font-semibold text-soft-white">Fato Vendas</span> por <span class="font-semibold text-soft-white">ID Venda</span>, evitando inflar valores em linhas de itens.
          </p>
        </article>

        <article class="store-data-pill">
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-success">
            Payload
          </p>
          <p class="text-sm leading-6 text-muted">
            Clientes e séries analíticas ficam em <span class="font-semibold text-soft-white">customers_kaminari.json</span>, com 180 clientes paginados em blocos de 20.
          </p>
        </article>

        <article class="store-data-pill">
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-success">
            Rails
          </p>
          <p class="text-sm leading-6 text-muted">
            O endpoint <span class="font-semibold text-soft-white">/api/customers</span> expõe os dados com metadados compatíveis com Kaminari para consumo em tabelas e gráficos.
          </p>
        </article>
      </div>
    </section>

    <main
      data-kpi-grid
      data-kpis-url="https://palermoc3.github.io/mei-commerce-analytics-dashboard/public/kpis.json"
      data-kpis-fallback-url="/kpis.json"
    >
      <section class="store-kpi-grid mb-6" data-kpi-primary-grid>
        <% [
          ["Receita de pedidos", "Faturamento confirmado"],
          ["Ticket médio", "Valor médio por pedido"],
          ["Lucro bruto", "Resultado antes de despesas"],
          ["Margem bruta", "Eficiência da operação"]
        ].each do |label, hint| %>
          <article class="mei-kpi-card store-kpi-card">
            <div class="flex h-full flex-col justify-between gap-5">
              <div>
                <span class="store-kpi-card-accent mb-4"></span>
                <p class="mei-kpi-card__label text-sm font-medium text-muted"><%= label %></p>
                <p class="mt-1 text-xs uppercase tracking-widest text-muted"><%= hint %></p>
              </div>
              <p class="mei-kpi-card__value text-3xl font-bold text-soft-white">—</p>
            </div>
          </article>
        <% end %>
      </section>

      <section class="store-main-grid mb-6">
        <article class="store-panel">
          <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="panel-title">
                Receita mensal
              </h2>
              <p class="text-sm text-muted">
                Evolução dos pedidos concluídos.
              </p>
            </div>
            <span class="w-fit rounded-full border border-success/30 bg-success/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-success">
              Vendas
            </span>
          </div>
          <div class="store-chart-frame" data-sales-chart-shell>
            <div class="store-chart-loader" role="status" aria-live="polite" aria-label="Carregando gráfico">
              <div class="store-quantum-loader" aria-hidden="true">
                <% 13.times do %>
                  <span class="store-quantum-particle"></span>
                <% end %>
              </div>
            </div>
            <div id="sales-chart" class="store-chart-surface h-[24rem] w-full" aria-busy="true"></div>
          </div>
        </article>

        <aside class="store-panel">
          <h2 class="panel-title mb-5">
            Operação agora
          </h2>
          <dl class="store-operation-list">
            <% [
              ["Pedidos concluídos", "operacao.completed_orders"],
              ["Unidades vendidas", "operacao.units_sold"],
              ["Produtos ativos", "operacao.products_active"],
              ["Avaliação média", "clientes.average_rating"],
              ["Carrinhos abertos", "clientes.open_carts"],
              ["Carrinhos abandonados", "clientes.abandoned_carts"]
            ].each do |label, key| %>
              <div class="store-operation-row">
                <dt class="text-sm text-muted"><%= label %></dt>
                <dd class="shrink-0 text-sm font-semibold text-soft-white" data-kpi-key="<%= key %>">—</dd>
              </div>
            <% end %>
          </dl>
        </aside>
      </section>

      <section>
        <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 class="panel-title">
              Métricas comerciais
            </h2>
            <p class="text-sm text-muted">
              Receita de itens, carrinhos e volume vendido.
            </p>
          </div>
        </div>

        <div class="store-metrics-grid" data-kpi-secondary-grid>
          <% [
            "Receita item",
            "Pedidos concluídos",
            "Unidades vendidas",
            "Produtos ativos",
            "Avaliação média",
            "Carrinhos abertos",
            "Carrinhos abandonados",
            "Valor em carrinhos"
          ].each do |label| %>
            <article class="mei-kpi-card store-metric-card">
              <p class="mei-kpi-card__label text-sm text-muted"><%= label %></p>
              <p class="mei-kpi-card__value mt-3 text-2xl font-semibold text-soft-white">—</p>
            </article>
          <% end %>
        </div>
      </section>

    </main>

    <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
    <script>
      window.initKpiDashboard = function initKpiDashboard() {
        const container = document.querySelector('[data-kpi-grid]');
        if (!container || container.dataset.loading === 'true') return;

        container.dataset.loading = 'true';

        const statusElement = document.querySelector('[data-kpi-status]');
        const kpisUrl = container.dataset.kpisUrl;
        const fallbackKpisUrl = container.dataset.kpisFallbackUrl;
        const keyMap = {
          'Receita de pedidos': 'receita.revenue',
          'Receita item': 'receita.item_revenue',
          'Ticket médio': 'receita.average_ticket',
          'Lucro bruto': 'rentabilidade.gross_profit',
          'Margem bruta': 'rentabilidade.gross_margin_percent',
          'Pedidos concluídos': 'operacao.completed_orders',
          'Unidades vendidas': 'operacao.units_sold',
          'Produtos ativos': 'operacao.products_active',
          'Avaliação média': 'clientes.average_rating',
          'Carrinhos abertos': 'clientes.open_carts',
          'Carrinhos abandonados': 'clientes.abandoned_carts',
          'Valor em carrinhos': 'clientes.cart_value'
        };

        const integerLabels = [
          'Pedidos concluídos',
          'Unidades vendidas',
          'Produtos ativos',
          'Carrinhos abertos',
          'Carrinhos abandonados'
        ];

        const setStatus = (message) => {
          if (statusElement) statusElement.textContent = message;
        };

        const chartShell = document.querySelector('[data-sales-chart-shell]');
        const chartReadyDelay = new Promise((resolve) => window.setTimeout(resolve, 5000));

        const revealChart = (chartContainer) => {
          chartReadyDelay.then(() => {
            chartShell?.classList.add('is-loaded');
            chartContainer?.setAttribute('aria-busy', 'false');
          });
        };

        chartShell?.classList.remove('is-loaded');
        document.getElementById('sales-chart')?.setAttribute('aria-busy', 'true');

        const getNestedValue = (obj, path) => {
          if (!path) return null;
          return path.split('.').reduce((acc, key) => (acc && acc[key] !== undefined ? acc[key] : null), obj);
        };

        const formatValue = (value, label) => {
          if (value === null || value === undefined) return '-';
          if (label === 'Margem bruta') return `${Number(value).toFixed(2)}%`;
          if (label === 'Avaliação média') return Number(value).toFixed(2);
          if (integerLabels.includes(label)) return Number(value).toLocaleString('pt-BR');

          if (typeof value === 'number') {
            return new Intl.NumberFormat('pt-BR', {
              style: 'currency',
              currency: 'BRL',
              minimumFractionDigits: 2,
              maximumFractionDigits: 2
            }).format(value);
          }

          return String(value);
        };

        const renderSvgChart = (chartContainer, sales) => {
          const months = sales.months || [];
          const values = sales.values || [];
          if (months.length === 0 || values.length === 0) return;
          const escapeHtml = (value) => String(value).replace(/[&<>"']/g, (char) => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
          }[char]));

          const width = 720;
          const height = 320;
          const padding = { top: 30, right: 72, bottom: 62, left: 78 };
          const minValue = Math.min(...values);
          const maxValue = Math.max(...values);
          const valueRange = Math.max(maxValue - minValue, 1);
          const plotWidth = width - padding.left - padding.right;
          const plotHeight = height - padding.top - padding.bottom;

          const points = values.map((value, index) => {
            const x = padding.left + (months.length === 1 ? plotWidth / 2 : (index / (months.length - 1)) * plotWidth);
            const y = padding.top + ((maxValue - value) / valueRange) * plotHeight;
            return { x, y, value, month: months[index] };
          });

          const path = points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(' ');
          const areaPath = `${path} L ${points[points.length - 1].x.toFixed(2)} ${height - padding.bottom} L ${points[0].x.toFixed(2)} ${height - padding.bottom} Z`;
          const currency = new Intl.NumberFormat('pt-BR', {
            style: 'currency',
            currency: 'BRL',
            maximumFractionDigits: 0
          });

          chartContainer.innerHTML = `
            <svg viewBox="0 0 ${width} ${height}" role="img" aria-label="Receita mensal de pedidos concluídos" class="h-full w-full">
              <defs>
                <linearGradient id="sales-chart-fill" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#10B981" stop-opacity="0.28"></stop>
                  <stop offset="100%" stop-color="#10B981" stop-opacity="0.02"></stop>
                </linearGradient>
              </defs>
              <rect width="${width}" height="${height}" rx="18" fill="rgba(15,23,42,0.18)"></rect>
              <line x1="${padding.left}" y1="${height - padding.bottom}" x2="${width - padding.right}" y2="${height - padding.bottom}" stroke="rgba(148,163,184,0.22)"></line>
              <line x1="${padding.left}" y1="${padding.top}" x2="${padding.left}" y2="${height - padding.bottom}" stroke="rgba(148,163,184,0.22)"></line>
              <text x="${padding.left}" y="20" fill="#94A3B8" font-size="13" font-weight="600">Receita mensal</text>
              <path d="${areaPath}" fill="url(#sales-chart-fill)"></path>
              <path d="${path}" fill="none" stroke="#10B981" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
              ${points.map((point) => `
                <g>
                  <circle cx="${point.x.toFixed(2)}" cy="${point.y.toFixed(2)}" r="6" fill="#10B981" stroke="#F1F5F9" stroke-width="2"></circle>
                  <text x="${point.x.toFixed(2)}" y="${(height - 26).toFixed(2)}" text-anchor="middle" fill="#94A3B8" font-size="12">${escapeHtml(point.month)}</text>
                  <text x="${point.x.toFixed(2)}" y="${(point.y - 14).toFixed(2)}" text-anchor="middle" fill="#F1F5F9" font-size="12" font-weight="700">${currency.format(point.value)}</text>
                </g>
              `).join('')}
            </svg>
          `;
        };

        const loadJson = (url) => fetch(url).then((response) => {
          if (!response.ok) throw new Error(`Falha ao carregar KPIs: ${response.status}`);
          return response.json();
        });

        const updateValues = (data, sourceLabel) => {
          document.querySelectorAll('.mei-kpi-card').forEach((card) => {
            const labelElement = card.querySelector('.mei-kpi-card__label');
            const valueElement = card.querySelector('.mei-kpi-card__value');
            if (!labelElement || !valueElement) return;

            const label = labelElement.textContent.trim();
            const value = getNestedValue(data, keyMap[label]);
            valueElement.textContent = formatValue(value, label);
          });

          document.querySelectorAll('[data-kpi-key]').forEach((element) => {
            const value = getNestedValue(data, element.dataset.kpiKey);
            const label = element.previousElementSibling?.textContent?.trim();
            element.textContent = formatValue(value, label);
          });

          const fallbackSales = {
            months: ['Jul 2024', 'Jan 2025', 'Jul 2025', 'Jan 2026', 'Jul 2026'],
            values: [6500, 7200, 6880, 7650, 7800]
          };
          const sales = data.sales || fallbackSales;
          const chartMonths = sales.months || fallbackSales.months;
          const chartValues = sales.values || fallbackSales.values;
          const chartContainer = document.getElementById('sales-chart');

          if (!chartContainer) {
            setStatus(sourceLabel);
            return;
          }

          if (window.Plotly) {
            const plotlyRender = Plotly.react(chartContainer, [{
              x: chartMonths,
              y: chartValues,
              type: 'scatter',
              mode: 'lines+markers',
              fill: 'tozeroy',
              fillcolor: 'rgba(16, 185, 129, 0.14)',
              hovertemplate: '%{x}<br>Receita: R$ %{y:,.0f}<extra></extra>',
              line: { color: '#10B981', width: 3.5, shape: 'spline', smoothing: 0.35 },
              marker: { size: 8, color: '#10B981', line: { color: '#E0F2FE', width: 1.5 } }
            }], {
              autosize: true,
              hovermode: 'x unified',
              title: { text: '', font: { color: '#F1F5F9' } },
              xaxis: {
                automargin: true,
                color: '#A7C7FF',
                fixedrange: true,
                gridcolor: 'rgba(148, 163, 184, 0.12)',
                range: [-0.2, chartMonths.length - 0.8],
                tickfont: { size: 13 },
                zeroline: false
              },
              yaxis: {
                automargin: true,
                tickprefix: 'R$ ',
                tickformat: ',.0f',
                color: '#A7C7FF',
                fixedrange: true,
                gridcolor: 'rgba(148, 163, 184, 0.12)',
                tickfont: { size: 13 },
                zeroline: false
              },
              margin: { l: 76, r: 56, t: 20, b: 62 },
              paper_bgcolor: 'rgba(0,0,0,0)',
              plot_bgcolor: 'rgba(15,23,42,0.26)',
              font: { color: '#F1F5F9', family: 'Inter, sans-serif' }
            }, {
              displayModeBar: false,
              responsive: true
            });

            Promise.resolve(plotlyRender)
              .then(() => revealChart(chartContainer))
              .catch((error) => {
                console.error('Erro ao renderizar Plotly:', error);
                renderSvgChart(chartContainer, sales);
                revealChart(chartContainer);
              });
          } else {
            renderSvgChart(chartContainer, sales);
            revealChart(chartContainer);
          }

          setStatus(sourceLabel);
        };

        setStatus('Carregando KPIs');

        loadJson(kpisUrl)
          .then((data) => updateValues(data, 'GitHub Pages conectado'))
          .catch(() => loadJson(fallbackKpisUrl).then((data) => updateValues(data, 'Fallback local conectado')))
          .catch((error) => {
            console.error('Erro ao atualizar KPIs:', error);
            document.querySelectorAll('.mei-kpi-card__value, [data-kpi-key]').forEach((element) => {
              element.textContent = '—';
            });
            revealChart(document.getElementById('sales-chart'));
            setStatus('KPIs indisponíveis');
          })
          .finally(() => {
            container.dataset.loading = 'false';
          });
      };

      if (!window.__kpiDashboardListenersAttached) {
        document.addEventListener('turbo:load', window.initKpiDashboard);
        document.addEventListener('DOMContentLoaded', window.initKpiDashboard);
        window.__kpiDashboardListenersAttached = true;
      }
    </script>
  </div>
</div>
