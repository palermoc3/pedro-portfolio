<%# ───────────── FLASH MESSAGES ───────────── %>
<% if notice %>
  <div data-controller="flash"  class="fixed top-20 right-4 z-50 bg-[#10B981] text-white px-4 py-3 rounded-lg shadow-lg text-sm">
    <%= notice %>
  </div>
<% end %>
<% if alert %>
  <div data-controller="flash"  class="fixed top-20 right-4 z-50 bg-red-500 text-white px-4 py-3 rounded-lg shadow-lg text-sm">
    <%= alert %>
  </div>
<% end %>

<%# ───────────── 1. HERO ───────────── %>
<section id="hero" class="mt-50 mb-20 flex items-center justify-center bg-[#0F172A] px-6">
  <div class="text-center max-w-3xl">
    <p class="text-[#6366F1] font-semibold tracking-widest uppercase text-sm mb-3 font-['Space_Grotesk']">Olá, eu sou</p>
    <h1 class="text-5xl md:text-7xl font-bold text-[#F1F5F9] mb-4 font-['Space_Grotesk']">Pedro Palermo</h1>
    <h2 class="text-2xl md:text-3xl text-[#94A3B8] mb-6 font-['Space_Grotesk']">Desenvolvedor Ruby on Rails</h2>
    <p class="text-[#94A3B8] text-lg mb-10 leading-relaxed">
      Construo aplicações web robustas e elegantes. Apaixonado por código limpo, boas práticas e aprendizado contínuo.
    </p>
  </div>
</section>

<%# ───────────── 2. SOBRE MIM ───────────── %>
<section id="sobre" class="py-24 bg-[#0F172A] px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-[#F1F5F9] mb-4 font-['Space_Grotesk']">Sobre mim</h2>
    <div class="w-12 h-1 bg-[#6366F1] mb-8 rounded"></div>
    <p class="text-[#94A3B8] text-lg leading-relaxed mb-10">
      Desenvolvedor Rails com 1 ano de experiência, focado em construir produtos que realmente funcionam.
      Gosto de entender o negócio por trás do código e de deixar cada detalhe bem feito —
      desde o banco de dados até a experiência do usuário.
    </p>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% [
        ["🧠", "Aprendizado rápido"],
        ["🤝", "Trabalho em equipe"],
        ["🔍", "Atenção aos detalhes"],
        ["📦", "Organização e foco"],
        ["💬", "Comunicação clara"],
        ["🚀", "Mentalidade de entrega"]
      ].each do |icon, skill| %>
        <li class="flex items-center gap-3 text-[#F1F5F9] bg-[#1E293B] px-4 py-3 rounded-lg">
          <span class="text-xl"><%= icon %></span>
          <span><%= skill %></span>
        </li>
      <% end %>
    </ul>
  </div>
</section>

<%# ───────────── 3. PROJETOS ───────────── %>
<section id="projetos" class="py-24 bg-[#1E293B] px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-[#F1F5F9] mb-4 font-['Space_Grotesk']">Projetos</h2>
    <div class="w-12 h-1 bg-[#6366F1] mb-10 rounded"></div>

    <%
      projects = [
        {
          name: "Portfólio com Dashboard",
          desc: "Portfólio pessoal com autenticação, dashboard de infográficos e integração com API do Brasileirão.",
          tags: ["Ruby on Rails", "PostgreSQL", "APIs"],
          demo: "/dashboard",
          github: "https://github.com/palermoc3/pedro-portfolio",
          icon: "📊"
        },
        {
          name: "Sistema de Navegação para Robô Autônomo",
          desc: "Desenvolvimento de lógica de controle baseada em sensores para seguimento de linha e evasão de obstáculos em ambiente simulado.",
          tags: ["Python", "Algoritmos", "Simulação"],
          demo: "https://www.youtube.com/watch?v=_gg8VvAYraU",
          icon: "🤖"
        },
        {
          name: "Ecommerce Portfólio",
          desc: "Exibição de loja virtual modular contendo fluxos completos de autenticação robusta, integração de gateways de pagamentos e upload de mídias.",
          tags: ["Ruby on Rails", "JavaScript", "Vue.js"],
          demo: "https://www.youtube.com/watch?v=LSvSzZZag3Y",
          github: "https://github.com/palermoc3/LojaVirtual",
          icon: "🛒"
        },
        {
         name: "XLSX E-commerce IA",
         desc: "Geração e validação de dataset analítico de e-commerce em XLSX, além de queries de negócio para métricas como ticket médio, margem, ranking de produtos e lucro mensal.",
         tags: ["Ruby on Rails", "SQLite", "caxlsx", "Business Intelligence"],
         demo: "https://github.com/palermoc3/xlsx_ecommerce_ia/",
          github: "https://github.com/palermoc3/xlsx_ecommerce_ia/",
          icon: "📈"
        }
      ]
    %>

    <%
      carousel_enabled = projects.size > 3
      collection_classes = carousel_enabled ? "projects-carousel-track" : "grid grid-cols-1 gap-5 md:grid-cols-3"
      item_classes = carousel_enabled ? "project-slide" : ""
    %>

    <div data-controller="<%= "projects-carousel" if carousel_enabled %>" class="projects-carousel">


      <% if carousel_enabled %>
        <div class="mt-5 flex items-center justify-between gap-4">
          <button type="button" class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#334155] bg-[#0F172A] text-[#F1F5F9] shadow-lg shadow-black/20 transition duration-200 hover:border-[#6366F1] hover:text-[#6366F1] focus:outline-none focus:ring-2 focus:ring-[#6366F1]/60" data-action="projects-carousel#previous" aria-label="Projetos anteriores">
            <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
          </button>

      <div class="<%= collection_classes %>" <%= 'data-projects-carousel-target="track" data-action="scroll->projects-carousel#update"'.html_safe if carousel_enabled %>>
        <% projects.each_with_index do |project, index| %>
          <div class="<%= item_classes %>" <%= 'data-projects-carousel-target="item"'.html_safe if carousel_enabled %>>
            <% demo_options = { class: "project-card-link", aria: { label: "Abrir apresentação de #{project[:name]}" } } %>
            <% demo_options.merge!(target: "_blank", rel: "noopener") if project[:demo].start_with?("http") %>

            <article class="project-card group">
              <%= link_to "", project[:demo], demo_options %>

              <div class="pointer-events-none relative h-24 overflow-hidden border-b border-[#1E293B] bg-[#1E293B]">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(99,102,241,0.22),_transparent_36%),linear-gradient(135deg,_#1E293B,_#0F172A)]"></div>
                <div class="relative flex h-full items-center justify-center">
                  <span class="text-4xl transition duration-200 group-hover:scale-110"><%= project[:icon] %></span>
                </div>
                <div class="absolute bottom-3 right-3 rounded-full bg-[#10B981]/10 px-2.5 py-1 text-[11px] font-semibold text-[#10B981] opacity-0 transition duration-200 group-hover:opacity-100">
                  Ver apresentação ↗
                </div>
              </div>

              <div class="pointer-events-none relative z-20 flex flex-1 flex-col justify-between p-4">
                <div>
                  <h3 class="mb-2 line-clamp-2 min-h-10 text-base font-bold leading-snug text-[#F1F5F9] transition duration-200 group-hover:text-[#6366F1] font-['Space_Grotesk']" title="<%= project[:name] %>">
                    <%= project[:name] %>
                  </h3>
                  <p class="line-clamp-3 text-sm leading-relaxed text-[#94A3B8]"><%= project[:desc] %></p>
                </div>

                <div class="mt-4 flex max-h-14 flex-wrap items-start gap-1.5 overflow-hidden" title="Repositório do Projeto">
                  <% if project[:github].present? %>
                    <%= link_to project[:github], target: "_blank", rel: "noopener", class: "pointer-events-auto relative z-30 rounded-full border border-[#10B981]/50 bg-[#10B981]/10 px-2.5 py-1 text-[11px] font-semibold text-[#10B981] transition duration-200 hover:border-[#10B981] hover:bg-[#10B981]/20" do %>
                      GitHub ↗
                    <% end %>
                  <% end %>
                  <% project[:tags].each do |tag| %>
                    <span class="max-w-[8.5rem] truncate rounded-full border border-[#6366F1]/30 bg-[#1E293B]/70 px-2.5 py-1 text-[11px] font-medium text-[#F1F5F9] transition duration-200 group-hover:border-[#6366F1]/60">
                      <%= tag %>
                    </span>
                  <% end %>
                </div>
              </div>
            </article>
          </div>
        <% end %>
      </div>

          <button type="button" class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#334155] bg-[#0F172A] text-[#F1F5F9] shadow-lg shadow-black/20 transition duration-200 hover:border-[#6366F1] hover:text-[#6366F1] focus:outline-none focus:ring-2 focus:ring-[#6366F1]/60" data-action="projects-carousel#next" aria-label="Próximos projetos">
            <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ───────────── 4. HABILIDADES ───────────── %>
<section id="habilidades" class="py-24 bg-[#0F172A] px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-[#F1F5F9] mb-4 font-['Space_Grotesk']">Habilidades</h2>
    <div class="w-12 h-1 bg-[#6366F1] mb-10 rounded"></div>
    <div class="flex flex-wrap gap-3">
      <% ["Ruby", "Ruby on Rails", "JavaScript", "Tailwind CSS", "PostgreSQL", "SQLite", "Git", "GitHub", "HTML5", "REST APIs"].each do |skill| %>
        <span class="bg-[#1E293B] text-[#F1F5F9] border border-[#6366F1]/40 px-4 py-2 rounded-full text-sm font-medium hover:border-[#6366F1] hover:text-[#6366F1] transition duration-200">
          <%= skill %>
        </span>
      <% end %>
    </div>
  </div>
</section>

